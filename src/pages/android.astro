---
import Layout from '../layouts/Layout.astro';

const pageTitle = "Build Android App - SiteToApp (APK Generator)";
const pageDescription = "Generate a high-performance native Android app (APK) from your website URL. Clean Gradle project generation, pull-to-refresh, custom icon support.";
---

<Layout title={pageTitle} description={pageDescription} bodyClass="builder-page">
  <main class="shell">
    <div class="workspace">
      
      <!-- Left Side: Form -->
      <form class="builder-panel" id="generatorForm">
        <div class="section-title">
          <h2>App Configuration</h2>
          <button class="icon-button" type="button" id="sampleButton" title="Fill sample values" aria-label="Fill sample values">
            <span aria-hidden="true">+</span>
          </button>
        </div>

        <label class="field">
          <span>Website URL</span>
          <input id="siteUrl" name="siteUrl" type="url" placeholder="https://example.com" autocomplete="url" required>
        </label>

        <div class="field-grid">
          <label class="field">
            <span>App Name</span>
            <input id="appName" name="appName" type="text" placeholder="My Web App" autocomplete="organization" required>
          </label>

          <label class="field">
            <span>Version</span>
            <input id="appVersion" name="appVersion" type="text" value="1.0.0" inputmode="decimal" required>
          </label>
        </div>

        <label class="field">
          <span>App ID (Package Name)</span>
          <div class="inline-control">
            <input id="appId" name="appId" type="text" placeholder="com.example.app" spellcheck="false" required>
            <button type="button" id="resetIdButton" class="btn btn-secondary">Auto</button>
          </div>
        </label>

        <label class="field">
          <span>App Icon (Optional 512x512 PNG)</span>
          <input id="appIcon" type="file" accept="image/png, image/jpeg">
        </label>

        <div class="icon-fetch-container" style="display: flex; align-items: center; justify-content: space-between; gap: 16px; margin-bottom: 24px; padding: 12px; border: 1px solid var(--accents-3); border-radius: var(--border-radius); background-color: rgba(0, 0, 0, 0.2);">
          <label class="check-row" style="border: none; margin: 0; padding: 0; background: transparent; display: flex; align-items: flex-start; gap: 12px; cursor: pointer;">
            <input id="autoFetchIcon" type="checkbox" checked style="margin-top: 4px; accent-color: #10b981;">
            <span style="display: flex; flex-direction: column; gap: 2px; text-align: left;">
              <strong style="font-size: 0.9rem; font-weight: 600;">Auto Fetch Website Icon</strong>
              <small style="font-size: 0.75rem; color: var(--accents-5); line-height: 1.4;">Scrapes the favicon of your site automatically</small>
            </span>
          </label>
          <div class="icon-preview-wrapper" style="width: 48px; height: 48px; border-radius: 8px; border: 1px solid var(--accents-3); display: grid; place-items: center; background-color: #000; overflow: hidden; flex-shrink: 0; position: relative;">
            <img id="iconPreview" src="" alt="Icon Preview" style="display: none; width: 100%; height: 100%; object-fit: cover;">
            <div id="iconPreviewPlaceholder" class="icon-preview-placeholder" style="font-weight: 800; color: var(--accents-4); font-size: 0.9rem;">SA</div>
            <div id="iconPreviewSpinner" class="spinner" style="display: none; margin: 0; border-color: rgba(255, 255, 255, 0.15); border-top-color: #10b981; position: absolute;"></div>
          </div>
        </div>

        <fieldset class="features-fieldset">
          <legend>Interface Settings</legend>
          <label class="check-row">
            <input id="showSpinner" type="checkbox" checked>
            <span>
              <strong>Horizontal Progress Indicator</strong>
              <small>Show a thin horizontal progress line on the top edge while pages load</small>
            </span>
          </label>
          <label class="check-row">
            <input id="pullToRefresh" type="checkbox" checked>
            <span>
              <strong>Pull-to-Refresh</strong>
              <small>Swipe down from the top to reload the page</small>
            </span>
          </label>
          <label class="check-row">
            <input id="allowZoom" type="checkbox">
            <span>
              <strong>Allow Zoom</strong>
              <small>Enable pinch-to-zoom controls in the WebView</small>
            </span>
          </label>
        </fieldset>

        <fieldset class="features-fieldset">
          <legend>Visual &amp; Launch Options</legend>
          <label class="check-row">
            <input id="showSplash" type="checkbox" checked>
            <span>
              <strong>Splash Screen</strong>
              <small>Show a centered logo splash screen on launch</small>
            </span>
          </label>
          
          <div class="field" id="splashDurationField" style="margin-bottom: 20px;">
            <span>Splash Screen Duration (ms)</span>
            <input id="splashDuration" type="number" value="2000" min="500" max="10000" style="width: 100%;">
          </div>

          <label class="check-row">
            <input id="fullScreen" type="checkbox">
            <span>
              <strong>Full Screen Mode</strong>
              <small>Hide the status bar and system navigation bar</small>
            </span>
          </label>
        </fieldset>

        <fieldset class="features-fieldset">
          <legend>Advanced Settings</legend>
          <div class="field">
            <span>Custom User Agent (Optional)</span>
            <input id="customUserAgent" type="text" placeholder="e.g. MyApp/1.0 (Android)" autocomplete="off">
          </div>
        </fieldset>

        <div class="actions">
          <button class="btn btn-primary" id="downloadButton" type="submit">
            Build & Download APK
          </button>
        </div>

        <!-- Build Progress -->
        <div class="build-progress" id="buildProgress" style="display: none;">
          <div class="progress-bar">
            <div class="progress-fill" id="progressFill"></div>
          </div>
          <p class="progress-text" id="progressText">Starting compilation…</p>
        </div>

        <p class="validation" id="validationMessage" aria-live="polite"></p>
      </form>

      <!-- Right Side: Preview & Meta -->
      <aside class="preview-panel" aria-label="App preview">
        
        <!-- Device Preview Frame -->
        <div class="device-preview" aria-hidden="true">
          <div class="phone">
            <div class="phone-bar"></div>
            <div class="screen">
              <span id="previewInitials">SA</span>
              <img id="previewIcon" src="" alt="App Icon" style="display: none; width: 54px; height: 54px; border-radius: 12px; object-fit: cover; box-shadow: var(--shadow-md);">
              <strong id="previewName">Site App</strong>
              <small id="previewUrl">https://example.com</small>
            </div>
          </div>
        </div>

        <!-- Build Summary -->
        <div class="section-title">
          <h2>Build Metadata</h2>
          <div class="status-pill" id="statusPill">Ready</div>
        </div>

        <dl class="output-meta">
          <div>
            <dt>App Name</dt>
            <dd id="outputAppName">Site App</dd>
          </div>
          <div>
            <dt>App ID</dt>
            <dd id="outputAppId">com.example.app</dd>
          </div>
          <div>
            <dt>Platform</dt>
            <dd id="artifactSummary">Android APK</dd>
          </div>
        </dl>

        <div class="build-info">
          <p>Building compiles a <strong>native Android Java wrapper project</strong> containing a lightweight high-performance WebView.</p>
          <ul>
            <li><strong>Zero Dependencies</strong> — Compiles using standard Android APIs.</li>
            <li><strong>CI/CD Pre-configured</strong> — Workspace ZIP includes GitHub Actions.</li>
          </ul>
        </div>
      </aside>

    </div>
  </main>
</Layout>

<script>
  import '../scripts/app.js';
</script>
