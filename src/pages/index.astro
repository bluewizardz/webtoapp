---
import Layout from '../layouts/Layout.astro';

const pageTitle = "SiteToApp - Free Website to APK Converter & App Wrapper";
const pageDescription = "Convert any website URL into a fully functional native Android app (APK) instantly with zero coding. High-performance, lightweight WebView wrapper, 100% free.";
---

<Layout title={pageTitle} description={pageDescription}>
  <main class="landing-main">
    <!-- Hero Section -->
    <section class="hero" aria-label="Product introduction">
      <div class="hero-container">
        <div class="hero-badge-wrapper" style="display: flex; gap: 8px; justify-content: center; flex-wrap: wrap;">
          <span class="hero-badge">Android Builder Live</span>
          <span class="hero-badge" style="color: #3ddc84; border-color: rgba(61, 220, 132, 0.3); background-color: rgba(61, 220, 132, 0.05);">No Login Required</span>
          <span class="hero-badge" style="color: #0070f3; border-color: rgba(0, 112, 243, 0.3); background-color: rgba(0, 112, 243, 0.05);">100% Free</span>
        </div>
        <h1 class="hero-title">
          Your website.<br>
          As a native application.
        </h1>
        <p class="hero-subtitle">
          Instantly package and compile any website URL into a native Android wrapper app (APK). Get a lightweight, high-performance mobile application with pull-to-refresh, loading indicators, and offline fallback—<strong>100% free, no login required, no cost</strong>.
        </p>
        <div class="hero-ctas">
          <a href="/android" class="btn btn-primary">Build Android App</a>
          <a href="#features" class="btn btn-secondary">Learn More</a>
        </div>
      </div>
    </section>

    <!-- Platforms Grid -->
    <section class="platforms-section" id="platforms" aria-label="Supported platforms">
      <div class="section-container">
        <h2 class="section-heading">Supported Platforms</h2>
        <div class="platforms-grid">
          
          <!-- Android Card (Active) -->
          <a href="/android" class="platform-card active-card" aria-label="Configure Android App">
            <div class="card-header">
              <span class="platform-icon android-icon">
                <svg viewBox="0 0 24 24" fill="currentColor" style="width: 32px; height: 32px; color: #3ddc84;" xmlns="http://www.w3.org/2000/svg">
                  <path d="M6 18c0 .55.45 1 1 1h1v3.5c0 .83.67 1.5 1.5 1.5s1.5-.67 1.5-1.5V19h2v3.5c0 .83.67 1.5 1.5 1.5s1.5-.67 1.5-1.5V19h1c.55 0 1-.45 1-1V8H6v10zM3.5 8C2.67 8 2 8.67 2 9.5v7c0 .83.67 1.5 1.5 1.5s1.5-.67 1.5-1.5v-7C5 8.67 4.33 8 3.5 8zm17 0c-.83 0-1.5.67-1.5 1.5v7c0 .83.67 1.5 1.5 1.5s1.5-.67 1.5-1.5v-7c0-.83-.67-1.5-1.5-1.5zm-3.5-3.56L18.42 2.9c.2-.31.11-.73-.2-1.01-.32-.2-.74-.11-.94.21l-1.34 2.1c-1.18-.5-2.52-.7-3.94-.7s-2.76.2-3.94.7L6.72 2.1c-.2-.32-.62-.41-.94-.21-.31.2-.4.62-.2 1.01l1.42 2.54C5.07 6.69 4 8.71 4 11h16c0-2.29-1.07-4.31-3-5.56zM9 8.5c-.55 0-1-.45-1-1s.45-1 1-1 1 .45 1 1-.45 1-1 1zm6 0c-.55 0-1-.45-1-1s.45-1 1-1 1 .45 1 1-.45 1-1 1z" />
                </svg>
              </span>
              <span class="badge badge-success">Active</span>
            </div>
            <h3 class="card-title">Android App Wrapper</h3>
            <p class="card-description">
              Convert your website into a high-performance native Android wrapper. Generates a clean Gradle project compiling to a lightweight APK.
            </p>
            <div class="card-footer">
              <span class="cta-link">Start Building &rarr;</span>
            </div>
          </a>

          <!-- macOS Card (Coming Soon) -->
          <div class="platform-card disabled-card">
            <div class="card-header">
              <span class="platform-icon macos-icon">
                <svg viewBox="0 0 24 24" fill="currentColor" style="width: 32px; height: 32px; color: #a3aaae;">
                  <path d="M18.71 19.5c-.83 1.24-1.71 2.45-3.05 2.47-1.34.03-1.77-.79-3.29-.79-1.53 0-2 .77-3.27.82-1.31.05-2.3-1.32-3.14-2.53C4.25 17 2.94 12.45 4.7 9.39c.87-1.52 2.43-2.48 4.12-2.51 1.28-.02 2.5.87 3.29.87.78 0 2.26-1.07 3.81-.91.65.03 2.47.26 3.64 1.98-.09.06-2.17 1.28-2.15 3.81.03 3.02 2.65 4.03 2.68 4.04-.03.07-.42 1.44-1.38 2.83M15.97 4.17c.66-.81 1.11-1.93.99-3.06-1 .04-2.2.67-2.92 1.51-.62.73-1.16 1.87-1.01 2.98 1.12.09 2.27-.61 2.94-1.43Z"/>
                </svg>
              </span>
              <span class="badge badge-neutral">Coming Soon</span>
            </div>
            <h3 class="card-title">macOS Desktop</h3>
            <p class="card-description">
              Electron framework wrapper packaging website into high performance DMG and ZIP packages for macOS.
            </p>
          </div>

          <!-- Windows Card (Coming Soon) -->
          <div class="platform-card disabled-card">
            <div class="card-header">
              <span class="platform-icon windows-icon">
                <svg viewBox="0 0 24 24" fill="currentColor" style="width: 32px; height: 32px; color: #0078d7;">
                  <path d="M0 3.449L9.75 2.1v9.45H0V3.449zM0 12.45h9.75v9.45L0 20.551v-8.1zM10.8 1.95L24 0v11.55H10.8V1.95zM10.8 12.45H24v11.55l-13.2-1.95v-9.6z"/>
                </svg>
              </span>
              <span class="badge badge-neutral">Coming Soon</span>
            </div>
            <h3 class="card-title">Windows Installer</h3>
            <p class="card-description">
              Produce professional NSIS installers (.exe) and portable Windows apps with direct system integration.
            </p>
          </div>

          <!-- Linux Card (Coming Soon) -->
          <div class="platform-card disabled-card">
            <div class="card-header">
              <span class="platform-icon linux-icon">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="width: 32px; height: 32px; color: #fcc729;">
                  <polyline points="4 17 10 11 4 5" />
                  <line x1="12" y1="19" x2="20" y2="19" />
                </svg>
              </span>
              <span class="badge badge-neutral">Coming Soon</span>
            </div>
            <h3 class="card-title">Linux Packages</h3>
            <p class="card-description">
              Generate AppImage and debian packages (.deb) ready for deployment on Ubuntu, Debian, and Linux Mint.
            </p>
          </div>

        </div>
      </div>
    </section>

    <!-- Features Section -->
    <section class="features-section" id="features" aria-label="Platform advantages">
      <div class="section-container">
        <div class="features-grid">
          <div class="feature-item">
            <h4 class="feature-title">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="width: 20px; height: 20px; color: #0070f3; display: inline-block; vertical-align: text-bottom; margin-right: 8px;">
                <line x1="12" y1="1" x2="12" y2="23"/>
                <path d="M17 5H9.5a3.5 3.5 0 0 0 0 7h5a3.5 3.5 0 0 1 0 7H6"/>
              </svg>
              Zero Server Costs
            </h4>
            <p class="feature-desc">
              Download the fully generated workspace ZIP pre-configured with **GitHub Actions**. Compile your apps completely for free using GitHub's runners.
            </p>
          </div>
          <div class="feature-item">
            <h4 class="feature-title">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="width: 20px; height: 20px; color: #f5a623; display: inline-block; vertical-align: text-bottom; margin-right: 8px;">
                <polygon points="13 2 3 14 12 14 11 22 21 10 12 10 13 2"/>
              </svg>
              High Performance
            </h4>
            <p class="feature-desc">
              By extending standard native Activity classes instead of bulky appcompat libraries, the final APK compiles to a tiny 31 KB bundle.
            </p>
          </div>
          <div class="feature-item">
            <h4 class="feature-title">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="width: 20px; height: 20px; color: #a3aaae; display: inline-block; vertical-align: text-bottom; margin-right: 8px;">
                <path d="M14.7 6.3a1 1 0 0 0 0 1.4l1.6 1.6a1 1 0 0 0 1.4 0l3.77-3.77a6 6 0 0 1-7.94 7.94l-6.91 6.91a2.12 2.12 0 0 1-3-3l6.91-6.91a6 6 0 0 1 7.94-7.94l-3.76 3.76z"/>
              </svg>
              Workspace Access
            </h4>
            <p class="feature-desc">
              Get full source code access. Build locally with Gradle, customize the layouts, and compile debug or release configurations.
            </p>
          </div>
        </div>
      </div>
    </section>
  </main>
</Layout>
