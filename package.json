{
  "name": "site2app-builder",
  "version": "1.0.0",
  "description": "Convert websites into native apps (APK, DMG, EXE, etc.)",
  "main": "server.js",
  "type": "module",
  "scripts": {
    "build": "astro build",
    "start": "npm run build && node server.js",
    "dev": "npm run build && node --watch server.js",
    "astro:build": "astro build",
    "astro:dev": "astro dev",
    "astro:preview": "astro preview"
  },
  "dependencies": {
    "archiver": "^6.0.0",
    "astro": "^6.4.2",
    "body-parser": "^1.20.2",
    "bullmq": "^5.77.6",
    "cors": "^2.8.5",
    "express": "^4.18.2",
    "ioredis": "^5.11.0",
    "sharp": "^0.32.0",
    "uuid": "^9.0.0",
    "xml2js": "^0.6.2"
  },
  "keywords": [
    "site2app",
    "apk",
    "dmg",
    "exe",
    "electron"
  ],
